flowchart TD
  start((Bắt đầu))
  canReview{Người dùng đã mua sản phẩm?}
  write["Viết đánh giá (form)"]
  submit["Gửi đánh giá"]
  validate{Nội dung hợp lệ?}
  save["Lưu đánh giá vào DB"]
  notify["Cập nhật rating trung bình / Thông báo admin"]
  edit["Yêu cầu chỉnh sửa nội dung"]
  finish((Kết thúc))

  start --> canReview
  canReview -- Không --> finish
  canReview -- Có --> write --> submit --> validate
  validate -- Có --> save --> notify --> finish
  validate -- Không --> edit --> write
