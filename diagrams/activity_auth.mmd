flowchart TD
  start((Bắt đầu))
  choose["Người dùng chọn: Đăng ký hoặc Đăng nhập"]
  decision{Chọn hành động}
  register["Đăng ký: điền thông tin"]
  sendVerify["Gửi email xác thực"]
  verify{Xác thực email?}
  createAccount["Tạo tài khoản"]
  loginFlow["Đăng nhập: nhập credentials"]
  authCheck{Credentials hợp lệ?}
  loginSuccess["Đăng nhập thành công"]
  error["Hiển thị lỗi"]
  finish((Kết thúc))

  start --> choose --> decision
  decision -- Đăng ký --> register --> sendVerify --> verify
  verify -- Có --> createAccount --> loginSuccess --> finish
  verify -- Không --> error --> finish
  decision -- Đăng nhập --> loginFlow --> authCheck
  authCheck -- Có --> loginSuccess --> finish
  authCheck -- Không --> error --> choose
