flowchart TD
  start((Bắt đầu))
  browse["Duyệt / Tìm kiếm sản phẩm"]
  view["Xem chi tiết sản phẩm"]
  addDecision{Thêm vào giỏ hàng?}
  cart["Xem giỏ hàng"]
  proceedCheckout{Tiến hành thanh toán?}
  loginCheck{Đã đăng nhập?}
  login["Hiển thị Đăng nhập / Đăng ký"]
  shipping["Nhập địa chỉ giao hàng"]
  applyCoupon{Áp dụng mã giảm giá?}
  validateCoupon["Xác thực mã giảm giá"]
  recalc["Cập nhật tổng tiền"]
  paymentMethod["Chọn phương thức thanh toán"]
  payment["Thanh toán qua cổng"]
  paymentResult{Thanh toán thành công?}
  createOrder["Tạo đơn hàng và gửi email xác nhận"]
  paymentError["Hiển thị lỗi thanh toán"]
  finish((Kết thúc))

  start --> browse
  browse --> view
  view --> addDecision
  addDecision -- Có --> cart
  addDecision -- Không --> browse
  cart --> proceedCheckout
  proceedCheckout -- Không --> browse
  proceedCheckout -- Có --> loginCheck
  loginCheck -- Không --> login
  login --> loginCheck
  loginCheck -- Có --> shipping
  shipping --> applyCoupon
  applyCoupon -- Có --> validateCoupon --> recalc
  applyCoupon -- Không --> recalc
  recalc --> paymentMethod --> payment --> paymentResult
  paymentResult -- Có --> createOrder --> finish
  paymentResult -- Không --> paymentError --> finish
